# ══════════════════════════════════════════════════════════════
# TaxOS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
APP_ENV=development          # "development" | "production"

# ── Database ───────────────────────────────────────────────────
# Dev: leave as SQLite
# Prod: use Supabase free tier → Settings → Database → Connection string
DATABASE_URL=sqlite:///./taxos.db
# DATABASE_URL=postgresql://user:password@host:5432/taxos

# ── Auth ───────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: generate with `openssl rand -hex 32`
JWT_SECRET=taxos-dev-secret-change-in-production

# ── AI (Required) ──────────────────────────────────────────────
# Get free key at https://console.mistral.ai (pay-per-use, no subscription)
MISTRAL_API_KEY=

# ── Email — Resend (free 3,000/month) ─────────────────────────
# Sign up free at https://resend.com — no credit card required
# Leave blank to use console fallback (dev mode)
RESEND_API_KEY=
EMAIL_FROM=TaxOS <noreply@yourdomain.com>

# ── File Storage ───────────────────────────────────────────────
# Dev: files saved to ./uploads/ (local disk)
# Prod option A — Cloudflare R2 (FREE: 10GB storage, free egress):
#   Sign up at https://cloudflare.com → R2 → Create bucket → API tokens
# Prod option B — AWS S3 (pay-per-use, very cheap)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=taxos-docs
AWS_REGION=ap-south-1
# For Cloudflare R2, also set:
# AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# AWS_REGION=auto
AWS_ENDPOINT_URL=

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:3001
# In production: ALLOWED_ORIGINS_STR=https://yourdomain.com

# ── Redis (optional — for future Celery workers) ───────────────
# Free at https://upstash.com (serverless Redis)
REDIS_URL=redis://localhost:6379/0

# ── Frontend (Next.js) ─────────────────────────────────────────
# Set this in frontend/.env.local (or Vercel env vars)
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
